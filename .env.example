# Supabase Configuration
# Copy this file to .env.local and fill in your values.
# Get these values from: https://supabase.com/dashboard → your project → Settings → API

# Your Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Your Supabase anonymous/public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Your Supabase service role key (⚠️ NEVER expose this to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
